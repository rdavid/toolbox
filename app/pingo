#
# Adds timestamps to the ping command output.
#
# File not following, appears unused:
#  shellcheck disable=SC1091,SC2034
set -- "$@" --quiet
readonly BASE_APP_VERSION=0.9.20260708
. base.sh

# Validates the environment and runs ping with timestamped output.
main() {
	validate "$@"
	process
}

# Runs ping with timestamped output.
process() {
	{
		ping "$TGT" 2>&1 1>&3 3>&- | tologe
	} 3>&1 1>&2 | totsout
}

# Validates the environment and sets TGT.
validate() {
	cmd_exists ping || die
	[ $# -ge 1 ] || die Host is not specified, try pingo [host].
	readonly TGT="$1"
}

# Entry point.
main "$@"
