#
# Wraps rsync and checks the installed version. If rsync is new enough, it uses
# append-verify and overall-progress output; otherwise it falls back to a safer
# option set supported by older rsync. Forwards every argument to rsync, so the
# last one is the destination.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
#  shellcheck disable=SC1091,SC2034,SC2039,SC3043
readonly BASE_APP_VERSION=0.9.20260626
. base.sh

# Validates arguments and runs the transfer.
main() {
	validate "$@"
	transfer "$@"
}

# Logs the rsync command with its arguments, then runs it, routing its stdout
# through tolog and its stderr through tologe.
run() {
	log rsync "$@"
	{
		rsync "$@" 2>&1 1>&3 3>&- | tologe
	} \
		3>&1 1>&2 | tolog
}

# Wraps rsync with a common option set and adds append-verify and
# overall-progress output for rsync 3.1+. Older rsync and openrsync run the
# base set only. The 3.1 gate compares MAJOR * 100 + MINOR against 301.
transfer() {
	local maj min ver
	ver="$(version)"
	maj="${ver%%.*}"
	min="${ver#*.}"
	min="${min%%.*}"
	if [ "$((maj * 100 + min))" -ge 301 ]; then
		log rsync version "$ver" is installed.
		set -- --append-verify --info=progress2 "$@"
	else
		logw rsync version "$ver" lacks newer options, using base set.
	fi
	run \
		--archive \
		--compress \
		--human-readable \
		--partial \
		--timeout=300 \
		--verbose \
		"$@"
}

# Validates the environment and arguments. Drops any rsync alias so the real
# binary runs regardless of the caller's shell configuration.
validate() {
	validate_cmd awk rsync
	unalias rsync 2>/dev/null || :
	[ "$#" -ge 2 ] ||
		die rsyncx: try rsyncx rsync-option... source... destination
}

# Prints the installed rsync version, the first MAJOR.MINOR(.PATCH) token from
# rsync --version, which copes with both the GNU rsync and the openrsync
# banners. Aborts via die when no version token is found.
version() {
	local ver
	ver="$(rsync --version 2>&1 |
		awk 'match($0, /[0-9]+\.[0-9]+(\.[0-9]+)?/) {
			print substr($0, RSTART, RLENGTH)
			exit
		}')"
	[ -n "$ver" ] || die Cannot determine rsync version.
	printf '%s\n' "$ver"
}

# Entry point.
main "$@"
