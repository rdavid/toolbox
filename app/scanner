#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2020-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# Detects if a device with a certain MAC address is in the local network.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
#  shellcheck disable=SC1091,SC2034,SC2039,SC3043
readonly BASE_APP_VERSION=0.9.20260708
. base.sh
MAXV=10
MINV=1
MIDL=$(((MAXV - MINV + 1) / 2))
readonly \
	MAXV \
	MIDL \
	MINV \
	SCAN=arp-scan\ --localnet\ --interface=wlan0
CNTR=$MIDL
NAME=''
ADDR=''

# Detects the target device in a loop.
main() {
	validate "$@"
	loop
}

# Validates that $1 is a well-formed MAC address.
is_mac() {
	printf '%s\n' "$1" |
		grep -E '^([0-9a-f]{2}:){5}[0-9a-f]{2}$' >/dev/null ||
		die MAC address "$1" is invalid.
}

# Scans for the target MAC address and reports its presence continuously.
loop() {
	while :; do
		scan
		report
		pause
	done
}

# Pauses between scans.
pause() {
	sleep 1
}

# Reports whether the device is home based on the counter.
report() {
	if [ $CNTR -gt $MIDL ]; then
		log "Master $NAME $ADDR is home: $CNTR!"
	else
		log "Master $MACA is not home: $CNTR."
	fi
}

# Scans the local network for the target MAC address. On a match it resets the
# counter to the maximum, since a success outweighs a failure.
# Word splitting required for SCAN args:
#  shellcheck disable=SC2086
scan() {
	local line
	line="$($SCAN | grep "$MACA" | head -1)" || :
	if [ -n "$line" ]; then
		[ -z "$NAME" ] && NAME="$(printf '%s' "$line" | cut -f1)"
		[ -z "$ADDR" ] && ADDR="$(printf '%s' "$line" | cut -f3 | xargs)"
		CNTR=$MAXV
	else
		[ $CNTR -gt $MINV ] && CNTR=$((CNTR - 1))
	fi
}

# Validates the environment and sets MACA.
# Word splitting required for SCAN args:
#  shellcheck disable=SC2086
validate() {
	beroot
	cmd_exists arp-scan || die
	[ "$#" -eq 1 ] || die scanner: try scanner [mac address:list]
	[ "$1" = list ] && {
		$SCAN
		cya
	}
	is_mac "$1"
	MACA="$1"
}

# Entry point.
main "$@"
