#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2019-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# The script downloads all new videos from pre-configured accounts in
# ytda.lst. It updates IDs of downloaded files at done.txt (ytda.dne in GitHub).
# The script can run as a cron job. Uses: curl, HandBrakeCLI, mp4track,
# renamr, rsync, transcode, transcode-video, yt-dlp.
# The script is run by cron, so the environment is strict.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# shellcheck disable=SC1091,SC2034,SC2039,SC3043
export \
	LANG=en_US.UTF-8 \
	LC_ALL=en_US.UTF-8 \
	PATH="$PATH":/usr/local/bin
readonly BASE_APP_VERSION=0.9.20260705
. base.sh

dir="$(realdir "$0")"/../cfg/ || die
AUT="$dir"ytda.aut
SRC="$dir"ytda.lst
unset dir
readonly \
	ARC=/mnt/nas-ibx/ytb/app/done.txt \
	AUD="$BASE_WIP"/aud \
	AUT \
	CKS=/mnt/nas-ibx/ytb/app/cookies.txt \
	DST=/mnt/nas-ibx/ytb \
	RES="$BASE_WIP"/res \
	SRC \
	VID="$BASE_WIP"/vid

# Downloads, renames, converts, uploads.
main() {
	validate
	download
	calc_wid
	rename
	sort
	convert
	upload
	check
}

# Calculates output table width for renamr and transcode utilities.
calc_wid() {
	local cols
	cols="$(tput cols 2>/dev/null || printf %s 79)"
	case "$cols" in
	'' | *[!0-9]*)
		cols=79
		;;
	esac
	WID=$((cols - $(printf '19700101-01:01:01 I ' | wc -m)))
	[ "$WID" -le 1 ] && die Terminal\'s width "$cols" is too small.
	readonly WID
}

# Verifies that every result file was copied to the destination. Keeps the
# results when none were copied or the counts differ.
check() {
	local ndst=0 nsrc=0 pipe
	pipe="$BASE_WIP"/pipe
	mkfifo "$pipe"
	find "$RES" -type f -exec basename {} \; >"$pipe" &
	while read -r name; do
		nsrc=$((nsrc + 1))
		[ -f "$DST/$name" ] && ndst=$((ndst + 1))
	done <"$pipe"
	rm "$pipe"
	if [ $nsrc -eq 0 ] || [ $nsrc -ne $ndst ]; then
		logw "There are $nsrc files in $RES, $ndst in $DST, keeps the results."
		[ "$BASE_KEEP_WIP" = true ] || keep_arc
	else
		log "Copied $nsrc files to $DST."
	fi
}

# Transcodes video and audio to standard formats.
convert() {
	if ! isempty "$VID"; then
		cd "$RES" || die Unable to change directory to "$RES".
		run transcode --act --dir "$VID" --out "$RES" --wid "$WID"
		rm -f ./*.log
		cd - || die Unable to change directory back.
	fi
	isempty "$AUD" ||
		run transcode --act --dir "$AUD" --mp3 --out "$RES" --wid "$WID"
}

# Downloads YouTube files. Stops when no new files were downloaded.
# shellcheck disable=SC2086 # Word splitting required for CKS_PARAM.
download() {
	run yt-dlp \
		$CKS_PARAM \
		--add-metadata \
		--batch-file=$SRC \
		--download-archive $ARC \
		--format bestvideo+bestaudio \
		--js-runtimes deno \
		--merge-output-format mp4 \
		--output "$VID/%(uploader)s-%(upload_date)s-%(title)s.%(ext)s" \
		--playlist-reverse
	isempty "$VID" || return 0
	cya No new videos were downloaded.
}

# Moves results to a local archive.
keep_arc() {
	local arc out who
	who="$(id -nu 2>&1)" || {
		loge "$who".
		who=none
	}
	arc="${BASE_WIP%.*}_arc_$who"
	if out="$(rm -fr "$arc" 2>&1)"; then
		mkdir "$arc"
		mv "$AUD" "$RES" "$VID" "$arc"
		cp "$BASE_WIP"/log "$arc"
		log The results are in "$arc".
	else
		loge "$out".
	fi
}

# Renames downloaded files to ASCII lower-case without spaces.
rename() {
	run renamr --act --dir "$VID" --wid "$WID"
}

# Routes the command's stdout to tolog and its stderr to tologe.
run() {
	{
		"$@" 2>&1 1>&3 3>&- | tologe
	} \
		3>&1 1>&2 | tolog
}

# Moves audio files by author into the audio folder.
sort() {
	while read -r a; do
		if file_exists "$VID/$a"*; then
			mv "$VID/$a"* "$AUD"
		fi
	done <"$AUT"
}

# Uploads the results to the destination.
# shellcheck disable=SC2086 # Word splitting required for DST.
upload() {
	isempty "$RES" && {
		log "No files to upload from $RES."
		return 0
	}
	run rsync --compress --human-readable --progress --verbose "$RES"/* $DST
}

# Verifies that required software packages are installed on the host.
validate() {
	local dir
	cmd_exists \
		deno \
		HandBrakeCLI \
		mp4track \
		renamr \
		rsync \
		tput \
		transcode \
		transcode-video \
		yt-dlp || die
	url_exists http://youtube.com || die Check internet connection.
	iswritable $DST $ARC || die Some directories are not writable.
	isreadable "$AUT" "$SRC" || die Some directories are not readable.
	for dir in $RES $AUD $VID; do
		mkdir -p "$dir" || die Unable to create "$dir".
	done
	if isreadable $CKS; then
		log Uses cookie $CKS.
		CKS_PARAM=--cookies\ $CKS
	else
		CKS_PARAM=''
	fi
	readonly CKS_PARAM
}

# Entry point.
main "$@"
