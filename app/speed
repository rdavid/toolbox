#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2020-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# Reports internet download and upload speeds in a loop.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# shellcheck disable=SC1091,SC2034,SC2039,SC3043
set -- "$@" --quiet
readonly BASE_APP_VERSION=0.9.20260705
. base.sh

# Reports download and upload internet speeds in a loop.
main() {
	validate
	loop
}

# Extracts the second whitespace-delimited token of the line labeled $2.
field() {
	printf %s "$1" | grep -E "^$2: " | gawk '{print $2}'
}

# Polls speedtest in a loop. The index starts at 0 so the title prints on
# the first iteration, then again every 30 iterations.
loop() {
	local i=0
	while :; do
		[ $((i % 30)) -eq 0 ] && title
		test_speed
		pause
		i=$((i + 1))
	done
}

# Pauses between speed checks.
pause() {
	sleep 30
}

# Prints current download and upload speeds, logging errors and returning early.
test_speed() {
	url_exists google.com || {
		loge Check internet connection.
		return 0
	}
	local down host out up
	out="$(speedtest-cli 2>&1)" || {
		loge "$out"
		return 0
	}
	down="$(field "$out" Download)" || {
		loge "$out: $down: down."
		return 0
	}
	up="$(field "$out" Upload)" || {
		loge "$out: $up: up."
		return 0
	}
	host="$(printf %s "$out" | grep -E '^Hosted by ' | cut -c11-)" || {
		loge "$out: $host: host."
		return 0
	}
	tsout "| $(printf %6s "$down") | $(printf %6s "$up") | $host"
}

# Prints top title.
title() {
	cat <<-EOM
		------------------+--------+--------+----------------
		    Timestamp     |  Down  |   Up   |   Hosted By
		------------------+--------+--------+----------------
	EOM
}

# Validates the environment.
validate() {
	cmd_exists gawk speedtest-cli || die
}

# Entry point.
main "$@"
