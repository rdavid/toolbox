#!/bin/sh
# vi: lbr noet sw=2 ts=2 tw=79 wrap
# SPDX-FileCopyrightText: 2022-2026 David Rabkin
# SPDX-License-Identifier: 0BSD
#
# Reports the external IP address and its location in a loop.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
#  shellcheck disable=SC1091,SC2034,SC2039,SC3043
set -- "$@" --quiet
readonly BASE_APP_VERSION=0.9.20260723
. base.sh

# Reports the external IP address and location in a loop.
main() {
	validate
	chrono_sta run || die
	loop
}

# Polls myip in a loop. The index starts at 0 so the title prints on the
# first iteration, then again every 24 iterations.
loop() {
	local i=0
	while :; do
		[ $((i % 24)) -eq 0 ] && title
		myip
		pause
		i=$((i + 1))
	done
}

# Prints the external IP address. Prefers the state/province for location,
# falling back to country, then to NO.
myip() {
	local dur ip out state
	ip="$(
		dig \
			-4 \
			+short \
			myip.opendns.com \
			@resolver4.opendns.com \
			2>&1
	)" || {
		loge OpenDNS failed: "$ip".
		return 0
	}
	var_exists ip || {
		ip="$(
			dig \
				-4 \
				-t txt \
				+short \
				o-o.myaddr.l.google.com \
				@ns1.google.com \
				2>&1
		)" || {
			loge Google DNS failed: "$ip".
			return 0
		}
		ip="$(printf %s "$ip" | awk -F\" '{print $2}')"
		var_exists ip || {
			loge OpenDNS and Google DNS failed to resolve the external IP.
			return 0
		}
	}
	out="$(whois "$ip" 2>&1)" || {
		loge whois "$ip" failed: "$out".
		return 0
	}
	state="$(pick "$out" stateprov)"
	var_exists state || state="$(pick "$out" country)"
	var_exists state || state=NO
	dur="$(chrono_get run)" || die
	ip="$(printf %15s "$ip")"
	tsout "| $ip |   $state  | $dur"
}

# Pauses between IP checks.
pause() {
	sleep 5
}

# Picks a colon-prefixed field from whois output and uppercases the value.
pick() {
	printf %s "$1" |
		awk -F':[ \t]+' "tolower(\$1) ~ /^$2\$/ {print toupper(\$2)}" |
		head -1
}

# Prints the table header.
title() {
	cat <<-EOM
		------------------+-----------------+-------+----------------
		    Timestamp     |        IP       | State |    Duration
		------------------+-----------------+-------+----------------
	EOM
}

# Validates the environment. Also uses the awk command, available on any
# Unix-like system.
validate() {
	cmd_exists dig whois || die
}

# Entry point.
main "$@"
