#
# Remounts filesystems using a temporary fstab, then restores the permanent
# one.
#
# File not following, appears unused:
#  shellcheck disable=SC1091,SC2034
readonly BASE_APP_VERSION=0.9.20260711
. base.sh
readonly \
	PRM=/etc/fstab-prm \
	TMP=/etc/fstab-tmp

# Remounts using the temporary fstab, then restores the permanent one.
main() {
	validate
	process
}

# Copies TMP to fstab, mounts all, then restores PRM. The PRM restore
# is unconditional so the system is never left with TMP as fstab.
process() {
	cp "$TMP" /etc/fstab || die Unable to copy "$TMP" to /etc/fstab.
	mount -a
	cp "$PRM" /etc/fstab || die Unable to restore /etc/fstab from "$PRM".
}

# Validates the environment.
validate() {
	beroot
	[ -f "$TMP" ] || die "$TMP" not found.
	[ -f "$PRM" ] || die "$PRM" not found.
}

# Entry point.
main "$@"
