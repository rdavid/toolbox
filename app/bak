#
# Makes incremental backups from the first parameter to the second.
#
# File not following, appears unused:
#  shellcheck disable=SC1091,SC2034
readonly BASE_APP_VERSION=0.9.20260708
. base.sh

# Runs the incremental backup from SRC to DST.
main() {
	validate "$@"
	process
}

# Executes rdiff-backup, routing stderr to the error log.
process() {
	{
		rdiff-backup \
			--force \
			--preserve-numerical-ids \
			--print-statistics \
			--terminal-verbosity 4 \
			"$SRC" "$DST" \
			2>&1 1>&3 3>&- | tologe
	} \
		3>&1 1>&2 | tolog
}

# Validates arguments and sets SRC and DST.
validate() {
	[ "$#" -eq 2 ] || die bak: try bak [src] [dst]
	readonly \
		DST="$2" \
		SRC="$1"
	isreadable "$SRC" || die "$SRC" is not readable.
	iswritable "$DST" || die "$DST" is not writable.
	cmd_exists rdiff-backup || die
}

# Entry point.
main "$@"
