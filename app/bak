# SPDX-License-Identifier: 0BSD
#
# Makes an incremental backup from the source directory to the destination.
#
# File not following, appears unused:
#  shellcheck disable=SC1091,SC2034
readonly \
	BASE_APP_VERSION=0.9.20260711 \
	BASE_MIN_VERSION=0.9.20260707
. base.sh

# Runs the incremental backup from SRC to DST.
main() {
	validate "$@"
	cmd_run rdiff-backup \
		--force \
		--preserve-numerical-ids \
		--print-statistics \
		--terminal-verbosity 4 \
		"$SRC" "$DST"
}

# Validates arguments and sets SRC and DST.
validate() {
	[ "$#" -eq 2 ] || die Usage: bak [src] [dst].
	readonly \
		DST="$2" \
		SRC="$1"
	isreadable "$SRC" || die "$SRC" is not readable.
	iswritable "$DST" || die "$DST" is not writable.
	cmd_exists rdiff-backup || die
}

# Entry point.
main "$@"
