#
# Converts a FLAC audio file to MP3.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# shellcheck disable=SC1091,SC2034,SC2039,SC3043
readonly BASE_APP_VERSION=0.9.20260609
. base.sh

# Converts SRC from FLAC to MP3 at DST.
main() {
	validate "$@"
	process
}

# Exports tags, transcodes audio, and writes DST.
process() {
	local tags
	log Converting "$SRC" to "$DST".
	tags="$(
		metaflac --export-tags-to=/dev/stdout "$SRC" |
			sed \
				-e 's/=/="/' \
				-e 's/$/"/' \
				-e 's/Album=/ALBUM=/' \
				-e 's/Genre=/GENRE=/' \
				-e 's/Artist=/ARTIST=/'
	)"
	printf '%s\n' "$tags"
	eval "$tags"
	flac -dc "$SRC" |
		lame \
			-b 320 \
			-h \
			--ta "${ARTIST}" \
			--tg "${GENRE}" \
			--tl "${ALBUM}" \
			--tn "${TRACKNUMBER}" \
			--tt "${TITLE}" \
			--ty "${DATE}" \
			--add-id3v2 /dev/stdin "$DST"
}

# Validates arguments and sets SRC and DST.
validate() {
	[ "$#" -eq 1 ] || die flactomp3: try flactomp3 [file]
	validate_cmd flac lame metaflac sed
	readonly SRC="$1"
	isreadable "$SRC" || die "$SRC" is not readable.
	iswritable . || die Current directory is not writable.

	# Strips the directory path and replaces the .flac extension with .mp3.
	DST="$(basename "$SRC" .flac).mp3"
	readonly DST
	file_exists "$DST" && { should_continue "$DST exists, overwrite" || cya; }
}

# Entry point.
main "$@"
