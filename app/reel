#
# Converts a video file to a vertical short-form reel.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
#  shellcheck disable=SC1091,SC2034,SC2039,SC3043
BASE_APP_USAGE="$(
	cat <<-EOM 2>&1
		  -c, --crop        Crop the center to fill the frame, no blurred copy.
		  -f, --file        Input file name (default input.mp4).
		  -g, --gap         Top and bottom gap in pixels with --crop (default 0).
		  -o, --output      Output file name (default output.mp4).
		  -s, --start       Start time, e.g. -s 00:00:05.00 (default 00:00:00.00).
		  -u, --duration    Clip duration, e.g. -u 00:00:15.00 (default 00:00:20.00).
	EOM
)" || {
	err=$?
	printf >&2 '%s\n' "$BASE_APP_USAGE"
	exit $err
}
readonly \
	BASE_APP_VERSION=0.9.20260708 \
	BASE_MIN_VERSION=0.9.20260707
. base.sh

# Validates the environment and converts the input video.
main() {
	validate "$@"
	process
}

# Checks that $1 is non-empty and not a flag, then assigns it to $3.
need() {
	case "${1:-}" in
	'' | -*) die "$2 requires a non-empty argument." ;;
	esac
	eval "${3}=\"\${1}\""
}

# Parses command-line arguments, consuming each option's value and dying on
# anything unrecognized.
parse() {
	while [ $# -gt 0 ]; do
		case "$1" in
		-c | --crop) CRP=true ;;
		-f | --file)
			need "${2:-}" --file FLE
			shift
			;;
		-g | --gap)
			need "${2:-}" --gap GAP
			shift
			;;
		-o | --output)
			need "${2:-}" --output OUT
			shift
			;;
		-s | --start)
			need "${2:-}" --start STA
			shift
			;;
		-u | --duration)
			need "${2:-}" --duration DUR
			shift
			;;
		*) die Unknown parameter "$1". ;;
		esac
		shift
	done
}

# Converts the input video to a vertical reel. With --crop the center of the
# video fills the frame, keeping a --gap sized black bar at the top and the
# bottom; otherwise the scaled video overlays its blurred copy. The ffmpeg
# options are sorted alphabetically, except -ss stays before -i for fast
# input seeking and the output file stays last.
process() {
	local hgt vfl
	hgt=$((1920 - 2 * GAP))
	if [ "$CRP" = true ]; then
		vfl="\
       crop='min(iw,ih*1080/$hgt)': \
       'min(ih,iw*$hgt/1080)', \
       scale=1080:$hgt, \
       setsar=1, \
       pad=1080:1920:0: \
       $GAP \
       "
	else
		vfl="\
       [0:v]split=2[bg][fg]; \
       [bg]scale=1080:1920, \
       setsar=1, \
       boxblur=20[blurred]; \
       [fg]scale=1080:-2[scaled]; \
       [blurred][scaled]overlay=(W-w)/2:(H-h)/2 \
       "
	fi
	cmd_run ffmpeg -y \
		-ss "$STA" \
		-i "$FLE" \
		-c:a aac -b:a 192k \
		-c:v libx264 -preset fast -crf 23 \
		-t "$DUR" \
		-vf "$vfl" \
		"$OUT"
}

# Validates the environment and sets defaults.
validate() {
	cmd_exists ffmpeg || die
	parse "$@"
	var_exists CRP || CRP=false
	var_exists DUR || DUR=00:00:20.00
	var_exists FLE || FLE=input.mp4
	var_exists GAP || GAP=0
	var_exists OUT || OUT=output.mp4
	var_exists STA || STA=00:00:00.00
	readonly \
		CRP \
		DUR \
		FLE \
		GAP \
		OUT \
		STA
	isnumber "$GAP" || die --gap requires a non-negative integer.
	[ "$GAP" -lt 960 ] || die --gap must be less than 960 pixels.
	[ "$CRP" = true ] || [ "$GAP" -eq 0 ] || die --gap requires --crop.
	isreadable "$FLE" || die "$FLE" is not readable.
	iswritable "$(dirname "$OUT")" || die "$OUT" is not writable.
}

# Entry point.
main "$@"
