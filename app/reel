#
# Converts a video file to a vertical short-form reel.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# shellcheck disable=SC2039,SC3043 # Uses local variables.
# shellcheck disable=SC1091,SC2034 # File not following, appears unused.
BASE_APP_USAGE="$(
	cat <<-EOM 2>&1
		  -f, --file        Input file name (default input.mp4).
		  -o, --output      Output file name (default output.mp4).
		  -s, --start       Start time, e.g. -s 00:00:05.00 (default 00:00:00.00).
		  -u, --duration    Clip duration, e.g. -u 00:00:15.00 (default 00:00:12.00).
	EOM
)" || {
	err=$?
	printf >&2 %s\\n "$BASE_APP_USAGE"
	exit $err
}
readonly BASE_APP_VERSION=0.9.20260606
. base.sh

# Validates the environment and converts the input video.
main() {
	validate "$@"
	process
}

# Converts the input video to a vertical reel.
process() {
	{
		ffmpeg -y \
			-ss "$STA" \
			-i "$FLE" \
			-t "$DUR" \
			-vf "[0:v]split=2[bg][fg]; \
       [bg]scale=1080:1920,setsar=1,boxblur=20[blurred]; \
       [fg]scale=1080:-2[scaled]; \
       [blurred][scaled]overlay=(W-w)/2:(H-h)/2" \
			-c:v libx264 -preset fast -crf 23 \
			-c:a aac -b:a 192k \
			"$OUT" \
			2>&1 1>&3 3>&- | tologe
	} \
		3>&1 1>&2 | tolog
}

# Checks that $1 is non-empty and not a flag, then assigns it to $3.
need() {
	case "${1:-}" in
	'' | -*) cya "$2 requires a non-empty argument." ;;
	esac
	eval "${3}=\"\${1}\""
}

# Parses command-line arguments.
parse() {
	local arg
	for arg; do
		shift
		case "$arg" in
		-f | --file) need "${1:-}" --file FLE ;;
		-o | --output) need "${1:-}" --output OUT ;;
		-s | --start) need "${1:-}" --start STA ;;
		-u | --duration) need "${1:-}" --duration DUR ;;
		esac
	done
}

# Validates the environment and sets defaults.
validate() {
	validate_cmd ffmpeg
	parse "$@"
	var_exists DUR || DUR=00:00:12.00
	var_exists FLE || FLE=input.mp4
	var_exists OUT || OUT=output.mp4
	var_exists STA || STA=00:00:00.00
	readonly \
		DUR \
		FLE \
		OUT \
		STA
	isreadable "$FLE" || die "$FLE" is not readable.
	iswritable "$(dirname "$OUT")" || die "$OUT" is not writable.
}

# Entry point.
main "$@"
