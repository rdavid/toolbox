#
# Validates image files.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# shellcheck disable=SC2039,SC3043 # Uses local variables.
# shellcheck disable=SC1091,SC2034 # File not following, appears unused.
readonly BASE_APP_VERSION=0.9.20260607
. base.sh

# Increments a named counter by one.
increment() {
	local val
	val="$(map_get cnt "$1")"
	map_put cnt "$1" $((val + 1))
}

# Validates images in DIR and reports results.
main() {
	validate "$@"
	scan
	report
}

# Scans DIR for image files (BMP, CR2, CRW, DNG, GIF, HEIC, JPEG, JPG, NEF,
# ORF, PNG, RAF, RW2, TIF) and validates each one.
scan() {
	local img
	map_put cnt all 0
	map_put cnt no 0
	map_put cnt ok 0
	find "$DIR" -type f \
		\( \
		-name '*.[bB][mM][pP]' -o \
		-name '*.[cC][rR]2' -o \
		-name '*.[cC][rR][wW]' -o \
		-name '*.[dD][nN][gG]' -o \
		-name '*.[gG][iI][fF]' -o \
		-name '*.[hH][eE][iI][cC]' -o \
		-name '*.[jJ][pP][eE][gG]' -o \
		-name '*.[jJ][pP][gG]' -o \
		-name '*.[nN][eE][fF]' -o \
		-name '*.[oO][rR][fF]' -o \
		-name '*.[pP][nN][gG]' -o \
		-name '*.[rR][aA][fF]' -o \
		-name '*.[rR][wW]2' -o \
		-name '*.[tT][iI][fF]' \
		\) |
		while read -r img; do
			process "$img"
		done
}

# Validates a single image and updates counters. Decodes to a raw pixel sink
# (rgb:/dev/null) to skip the temporary file write on every image.
process() {
	local img out
	img="$1"
	increment all
	if out="$(magick "$img" rgb:/dev/null 2>&1)"; then
		increment ok
		log ok "$img"
	else
		increment no
		logw no "$img: $out"
	fi
}

# Prints ok and no totals, or a notice when no files were processed.
report() {
	local all no ok
	all="$(map_get cnt all)"
	[ "$all" -eq 0 ] && {
		log No files to validate.
		return 0
	}
	no="$(map_get cnt no)"
	ok="$(map_get cnt ok)"
	[ "$ok" -eq 0 ] || log ok "$ok/$all".
	[ "$no" -eq 0 ] || logw no "$no/$all".
}

# Validates the environment and sets defaults.
validate() {
	validate_cmd magick
	[ "$#" -eq 1 ] || cya ival: try ival [user directory]
	readonly DIR="$1"
	isreadable "$DIR" || die Directory "$DIR" is not readable.
}

# Entry point.
main "$@"
