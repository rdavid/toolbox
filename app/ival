#
# Validates image files.
#
# shellcheck disable=SC1091,SC2034 # File not following, variable unused.
readonly BASE_APP_VERSION=0.9.20260604
. base.sh
validate_cmd convert
[ "$#" -eq 1 ] || cya ival: try ival [user directory]
readonly DIR="$1"
isreadable "$DIR" || die Directory "$DIR" is not readable.
map_put cnt all 0
map_put cnt no 0
map_put cnt ok 0
find "$DIR" \
	\( \
	-name '*.[dD][nN][gG]' \
	-o \
	-name '*.[hH][eE][iI][cC]' \
	-o \
	-name '*.[jJ][pP][gG]' \
	-o \
	-name '*.[nN][eE][fF]' \
	-o \
	-name '*.[rR][aA][fF]' \
	\) \
	-type f |
	while read -r img; do
		all="$(map_get cnt all)"
		all=$((all + 1))
		map_put cnt all "$all"
		if convert "$img" "$BASE_DIR_WIP/out.tiff" >/dev/null 2>&1; then
			num="$(map_get cnt ok)"
			num=$((num + 1))
			map_put cnt ok "$num"
			log ok "$all" "$img"
		else
			num="$(map_get cnt no)"
			num=$((num + 1))
			map_put cnt no "$num"
			logw no "$all" "$img"
		fi
	done
all="$(map_get cnt all)"
num="$(map_get cnt ok)"
[ "$num" -eq 0 ] || log ok "$num/$all".
num="$(map_get cnt no)"
[ "$num" -eq 0 ] || logw no "$num/$all".
