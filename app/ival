#
# Validates image files.
#
# The script uses local variables which are not POSIX but supported by most
# shells. See:
#  https://stackoverflow.com/q/18597697
# shellcheck disable=SC1091,SC2034,SC2039,SC3043
readonly BASE_APP_VERSION=0.9.20260626
. base.sh

# Validates images in DIR and reports results.
main() {
	validate "$@"
	scan
	report
}

# Logs the given directory as a header: once when it differs from the
# previously seen one, then again every 100 files within that same directory
# as a progress marker for directories holding more than 100 files, so the
# per-file lines below only need the basename. State is persisted in the
# file-backed map (bucket "prv" for the last directory, bucket "cnt" key "cur"
# for the count within it) to survive scan()'s pipe subshell.
header() {
	local dir="$1" out prv
	prv="$(map_get prv dir 2>&1)" || die "$prv"
	if [ "$dir" = "$prv" ]; then
		[ $(($(increment cur) % 100)) -eq 0 ] && log "$dir"
		return
	fi
	out="$(map_put prv dir "$dir" 2>&1)" || die "$out"
	map_put cnt cur 0
	log "$dir"
}

# Increments a named counter by one and prints its new value.
increment() {
	local out val
	val="$(map_get cnt "$1" 2>&1)" || die "$val"
	val=$((val + 1))
	out="$(map_put cnt "$1" "$val" 2>&1)" || die "$out"
	printf '%s\n' "$val"
}

# Validates a single image and updates counters. Decodes to a raw pixel sink
# (rgb:/dev/null) to skip the temporary file write on every image. Logs the
# basename on success, but the full path on failure so the offending file is
# unambiguous regardless of the directory header above it.
process() {
	local dir img="$1" nme out
	dir="${img%/*}"
	nme="${img##*/}"
	header "$dir"
	increment all
	if out="$(magick "$img" rgb:/dev/null 2>&1)"; then
		increment ok
		log ok "$nme"
	else
		increment no
		logw no "$img: $out"
	fi
}

# Prints a single ok/no/all summary, or a notice when no files were processed.
report() {
	local all no ok
	all="$(map_get cnt all)"
	[ "$all" -eq 0 ] && {
		log No files to validate.
		return 0
	}
	no="$(map_get cnt no)"
	ok="$(map_get cnt ok)"
	if [ "$no" -eq 0 ]; then
		log "ok: $ok."
	else
		logw "ok/no/all: $ok/$no/$all."
	fi
}

# Scans DIR for image files (ARW, BMP, CR2, CR3, CRW, DNG, GIF, HEIC, HEIF,
# JPEG, JPG, NEF, ORF, PNG, RAF, RW2, TIF, TIFF, WEBP) and validates each one.
# Discards the loop's stdout, which carries only the counter values that
# increment() prints; header() captures the one it needs via command
# substitution.
scan() {
	local img
	map_put cnt all 0
	map_put cnt no 0
	map_put cnt ok 0
	map_put prv dir ''
	find "$DIR" -type f \
		\( \
		-name '*.[aA][rR][wW]' -o \
		-name '*.[bB][mM][pP]' -o \
		-name '*.[cC][rR]2' -o \
		-name '*.[cC][rR]3' -o \
		-name '*.[cC][rR][wW]' -o \
		-name '*.[dD][nN][gG]' -o \
		-name '*.[gG][iI][fF]' -o \
		-name '*.[hH][eE][iI][cC]' -o \
		-name '*.[hH][eE][iI][fF]' -o \
		-name '*.[jJ][pP][eE][gG]' -o \
		-name '*.[jJ][pP][gG]' -o \
		-name '*.[nN][eE][fF]' -o \
		-name '*.[oO][rR][fF]' -o \
		-name '*.[pP][nN][gG]' -o \
		-name '*.[rR][aA][fF]' -o \
		-name '*.[rR][wW]2' -o \
		-name '*.[tT][iI][fF]' -o \
		-name '*.[tT][iI][fF][fF]' -o \
		-name '*.[wW][eE][bB][pP]' \
		\) |
		sort |
		while read -r img; do
			process "$img"
		done >/dev/null
}

# Validates the environment and sets defaults.
validate() {
	validate_cmd magick
	[ "$#" -eq 1 ] || cya ival: try ival [user directory]
	readonly DIR="$1"
	isreadable "$DIR" || die Directory "$DIR" is not readable.
}

# Entry point.
main "$@"
